@page "/"
@rendermode InteractiveServer

<PageTitle>Fruits de @(CurrentUser?.Username ?? "Connexion")</PageTitle>

@if (CurrentUser == null) {
    <div class="container mt-5 text-center">
        <div class="card p-4 shadow-sm mx-auto" style="max-width: 400px;">
            <h4>Connexion</h4>
            <input class="form-control mb-2" @bind="Username" placeholder="Utilisateur" />
            <input type="password" class="form-control mb-3" @bind="Password" placeholder="Mot de passe" />
            <button class="btn btn-primary w-100" @onclick="LoginUser">Entrer</button>
            @if (!string.IsNullOrEmpty(ErrorMessage)) { <p class="text-danger mt-2">@ErrorMessage</p> }
        </div>
    </div>
} else {
    <div class="container mt-4">
        <div class="d-flex justify-content-between border-bottom pb-3">
            <h2>Mes Fruits (@CurrentUser.Username)</h2>
            <button class="btn btn-sm btn-outline-danger" @onclick="Logout">Déconnexion</button>
        </div>
        <div class="text-end my-3">
            <a href="/add" class="btn btn-success">+ Ajouter un fruit</a>
        </div>
        <table class="table table-striped">
            <thead>
                <tr><th>Nom</th><th class="text-center">Favori</th><th class="text-center">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var f in _fruitList ?? []) {
                    <tr>
                        <td>@f.name</td>
                        <td class="text-center">@(f.instock ? "⭐" : "❌")</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-primary" @onclick="() => EditButton(f.id)">Modifier</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteButton(f.id)">Supprimer</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}